# Keep the build context small and stable for the hermetic stagex build.
.git
target
out
# Exclude the large `reference` C submodule, but keep the KAT vectors: the
# verify crate's tests `include_str!` them, so they must be in the build context.
# `!reference/KAT` re-includes the directory and `!reference/KAT/**` its contents
# (explicit so the negation is unambiguous across Docker/BuildKit versions).
reference/*
!reference/KAT
!reference/KAT/**
**/*.sage.py
flamegraph.svg
dhat-heap.json
